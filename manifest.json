{
  "manifest_version": 3,
  "name": "AI Data Shield",
  "version": "1.5.0",
  "description": "Enterprise local redaction layer for safe AI use.",
  "permissions": ["storage", "activeTab"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["*://chatgpt.com/*", "*://*.openai.com/*", "*://*.anthropic.com/*"],
      "js": ["content.js"]
    }
  ]
}